    <item>
      <title>抗旋轉鈦基底 (Ti-Base)</title>
      <link>http://localhost:65279/Dental-implants/posts/ti-base/</link>
      <pubDate>Tue, 13 Jan 2026 10:00:00 +0800</pubDate>
      <guid>http://localhost:65279/Dental-implants/posts/ti-base/</guid>
      <description>&lt;h2 id=&#34;-產品價格-product-price&#34;&gt;💰 產品價格 &lt;small&gt;Product Price&lt;/small&gt;&lt;/h2&gt;&#xA;&lt;div class=&#34;price-display my-4&#34;&gt;&#xA;    &lt;span class=&#34;original-price text-base-content/60 text-lg mr-2&#34; style=&#34;text-decoration: line-through;&#34;&gt;原價 10 美元&lt;/span&gt;&#xA;    &lt;span class=&#34;special-price text-2xl font-bold&#34; style=&#34;color: red;&#34;&gt;特價 5 美元&lt;/span&gt;&#xA;&lt;/div&gt;&#xA;&#xA;&#xA;&#xA;  &lt;blockquote&gt;&#xA;    &lt;p&gt;&lt;strong&gt;工廠直銷價：面議 / 批量更有優惠&lt;/strong&gt;&#xA;&lt;br&gt;&lt;small&gt;Factory Direct Price: Negotiable / Bulk discounts available&lt;/small&gt;&#xA;&lt;a href=&#34;http://localhost:65279/Dental-implants/about/#contact&#34;&gt;☎️ 歡迎聯繫詢價獲取最新報價單 &lt;small&gt;Contact us for the latest price list&lt;/small&gt;&lt;/a&gt;&lt;/p&gt;&#xA;&#xA;  &lt;/blockquote&gt;&#xA;&#xA;&lt;h2 id=&#34;-產品圖片-product-images&#34;&gt;📸 產品圖片 &lt;small&gt;Product Images&lt;/small&gt;&lt;/h2&gt;&#xA;&lt;p&gt;&lt;img src=&#34;http://localhost:65279/Dental-implants/img/ti-base.png&#34; alt=&#34;抗旋轉鈦基底 (Ti-Base)&#34;&gt;&lt;/p&gt;&#xA;&lt;h2 id=&#34;產品特性-product-features&#34;&gt;產品特性 &lt;small&gt;Product Features&lt;/small&gt;&lt;/h2&gt;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;&lt;strong&gt;金色陽極氧化&lt;/strong&gt;：模擬天然牙本質顏色，避免牙齦透黑，實現完美美學效果。&lt;/li&gt;&#xA;&lt;li&gt;&lt;strong&gt;固位溝槽設計&lt;/strong&gt;：特殊的固位紋理設計，顯著增加粘接面積，確保牙冠長期穩固。&lt;/li&gt;&#xA;&lt;li&gt;&lt;strong&gt;標準數據庫&lt;/strong&gt;：提供標準的數字化數據庫文件（Library），兼容 3Shape 與 Exocad。&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;h2 id=&#34;技術規格-technical-specifications&#34;&gt;技術規格 &lt;small&gt;Technical Specifications&lt;/small&gt;&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th style=&#34;text-align: left&#34;&gt;規格項目 &lt;br&gt;&lt;small&gt;Specification&lt;/small&gt;&lt;/th&gt;&#xA;          &lt;th style=&#34;text-align: left&#34;&gt;參數 &lt;br&gt;&lt;small&gt;Parameter&lt;/small&gt;&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;材質 &lt;br&gt;&lt;small&gt;Material&lt;/small&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Ti-6Al-4V ELI (Grade 5)&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;表面處理&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;金色陽極氧化 / 噴砂&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;穿齦高度&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;0.5mm / 1.5mm / 2.5mm&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;類型&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;抗旋轉 (單冠) / 非抗旋轉 (橋體)&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;div class=&#34;purchase-options my-8&#34;&gt;&#xA;    &lt;h2 class=&#34;text-xl font-bold mb-4&#34;&gt;🛒 購買渠道 &lt;small class=&#34;text-base font-normal ml-2&#34;&gt;Purchase Channels&lt;/small&gt;&lt;/h2&gt;&#xA;    &lt;div class=&#34;flex flex-row justify-center items-start text-center&#34; style=&#34;column-gap: 80px;&#34;&gt;&#xA;&#xA;        &#xA;        &lt;a href=&#34;%20#&#34; target=&#34;_blank&#34; class=&#34;flex flex-col items-center group&#34;&gt;&#xA;            &lt;div class=&#34;w-[150px] h-[150px] mb-2&#34;&gt;&#xA;                &#xA;                &lt;img src=&#34;http://localhost:65279/Dental-implants/img/Taobao.png&#34; alt=&#34;Taobao&#34; class=&#34;w-full h-full object-contain&#34;&#xA;                    style=&#34;width: 150px; height: 150px; object-fit: contain;&#34; /&gt;&#xA;            &lt;/div&gt;&#xA;            &lt;span class=&#34;font-semibold group-hover:text-orange-500&#34;&gt;淘寶購買 &lt;br&gt;&lt;small&#xA;                    class=&#34;font-normal text-xs text-base-content/60&#34;&gt;Taobao&lt;/small&gt;&lt;/span&gt;&#xA;        &lt;/a&gt;&#xA;&#xA;        &#xA;        &lt;a href=&#34;%20#&#34; target=&#34;_blank&#34; class=&#34;flex flex-col items-center group&#34;&gt;&#xA;            &lt;div class=&#34;w-[150px] h-[150px] mb-2&#34;&gt;&#xA;                &#xA;                &lt;img src=&#34;http://localhost:65279/Dental-implants/img/Shopee.png&#34; alt=&#34;Shopee&#34; class=&#34;w-full h-full object-contain&#34;&#xA;                    style=&#34;width: 150px; height: 150px; object-fit: contain;&#34; /&gt;&#xA;            &lt;/div&gt;&#xA;            &lt;span class=&#34;font-semibold group-hover:text-orange-600&#34;&gt;蝦皮購買 &lt;br&gt;&lt;small&#xA;                    class=&#34;font-normal text-xs text-base-content/60&#34;&gt;Shopee&lt;/small&gt;&lt;/span&gt;&#xA;        &lt;/a&gt;&#xA;&#xA;        &#xA;        &lt;div class=&#34;flex flex-col items-center cursor-pointer&#34;&#xA;            onclick=&#34;document.getElementById(&#39;wechat_modal&#39;).showModal()&#34;&gt;&#xA;            &lt;div class=&#34;w-[150px] h-[150px] mb-2&#34;&gt;&#xA;                &#xA;                &lt;img src=&#34;http://localhost:65279/Dental-implants/img/wechat-qr.jpg&#34; alt=&#34;WeChat&#34; class=&#34;w-full h-full object-contain&#34;&#xA;                    style=&#34;width: 150px; height: 150px; object-fit: contain;&#34; /&gt;&#xA;            &lt;/div&gt;&#xA;            &lt;span class=&#34;font-semibold&#34;&gt;微信諮詢 &lt;br&gt;&lt;small&#xA;                    class=&#34;font-normal text-xs text-base-content/60&#34;&gt;WeChat&lt;/small&gt;&lt;/span&gt;&#xA;        &lt;/div&gt;&#xA;&#xA;    &lt;/div&gt;&#xA;&#xA;    &#xA;    &lt;dialog id=&#34;wechat_modal&#34; class=&#34;modal&#34;&gt;&#xA;        &lt;div class=&#34;modal-box text-center&#34;&gt;&#xA;            &lt;h3 class=&#34;font-bold text-lg mb-4&#34;&gt;微信掃碼諮詢 &lt;br&gt;&lt;small class=&#34;font-normal text-sm&#34;&gt;Scan QR Code to Add&#xA;                    WeChat&lt;/small&gt;&lt;/h3&gt;&#xA;            &lt;div class=&#34;flex justify-center&#34;&gt;&#xA;                &#xA;                &lt;img src=&#34;http://localhost:65279/Dental-implants/img/wechat-qr.jpg&#34; alt=&#34;WeChat QR Code&#34;&#xA;                    class=&#34;w-64 h-64 object-contain border rounded-lg&#34; /&gt;&#xA;            &lt;/div&gt;&#xA;            &lt;p class=&#34;py-4 text-sm text-base-content/60&#34;&gt;請使用微信掃描上方二維碼&lt;/p&gt;</description>
